NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ADMIN_PASSWORD=change-me
IP_HASH_SALT=change-this-to-a-long-random-string

# HMAC secret for browser session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Secret Vercel Cron will use to call /api/cron/expire-seeds.
# Generate with the same command as above.
CRON_SECRET=

# OpenAI moderation — toxicity scoring on note submissions.
# Free endpoint: https://platform.openai.com/api-keys
# If unset, the toxicity check is skipped (the rest of the pipeline still runs).
OPENAI_API_KEY=

# Cloudflare Turnstile — captcha on note submissions.
# Create a widget at https://dash.cloudflare.com -> Turnstile.
# If either is unset, captcha is skipped (the other gates still apply).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
