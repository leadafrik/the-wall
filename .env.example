NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ADMIN_PASSWORD=change-me
IP_HASH_SALT=change-this-to-a-long-random-string

# HMAC secret for browser session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# OpenAI moderation — toxicity scoring on note submissions.
# Free endpoint: https://platform.openai.com/api-keys
# If unset, the toxicity check is skipped (the rest of the pipeline still runs).
OPENAI_API_KEY=
